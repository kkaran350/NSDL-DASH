# The spreadsheet ID from the sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
SHEET_ID=1YPtcxrCWvBjHToYvVgsENSylomV0hYsy8R3kuq-S_9Y

# The gid from the sheet's URL (the number after #gid= on the tab you want)
SHEET_GID=0

# "csv" (default) reads the sheet's public CSV export — no credentials
# needed, but the sheet must be shared as "Anyone with the link can view".
# "api" reads via the Google Sheets API v4 and needs GOOGLE_SHEETS_API_KEY
# below, plus the sheet still needs to be viewable by that key's project
# (or swap to a service account for a fully private sheet).
SHEET_ACCESS_MODE=csv

# Only needed if SHEET_ACCESS_MODE=api
GOOGLE_SHEETS_API_KEY=

# Only used in "api" mode — sheet tab name (or a full A1 range) to read
SHEET_RANGE=Sheet1
# Site-wide login (Basic Auth). Leave both blank to keep the site open;
# set both to require this username/password before anything loads.
APP_USERNAME=MittalDashboard
APP_PASSWORD=Dash@1234
# Optional UI labels. NEXT_PUBLIC_ORG_NAME sets the name in the dashboard
# header and on the login card; leave unset for "Mittal Portfolios Pvt. Ltd."
NEXT_PUBLIC_ORG_NAME=

# Optional. When set, the account menu (cube button, top-left) shows a Zoho
# button that opens this URL. Left blank, the button is hidden.
NEXT_PUBLIC_ZOHO_URL=
